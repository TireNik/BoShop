<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE module PUBLIC "-//Puppy Crawl//DTD Check Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="fileExtensions" value="java"/>

    <!-- Проверка длины строки -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|href|http://|https://"/>
    </module>

    <!-- Проверка наличия Javadoc у публичных методов -->
    <module name="JavadocMethod">
        <property name="allowedAnnotations" value="Override, Test"/>
        <property name="allowMissingParamTags" value="true"/>
        <property name="allowMissingReturnTag" value="true"/>
    </module>

    <!-- Проверка имен методов -->
    <module name="MethodName">
        <property name="format" value="^[a-z][a-zA-Z0-9_]*$"/>
    </module>

    <!-- Проверка имен локальных переменных -->
    <module name="LocalVariableName">
        <property name="format" value="^[a-z]([a-z0-9][a-zA-Z0-9]*)?$"/>
    </module>

    <!-- Проверка отступов вокруг операторов -->
    <module name="WhitespaceAround">
        <property name="tokens" value="ASSIGN, BAND, BAND_ASSIGN, BOR, BOR_ASSIGN, BSR, BSR_ASSIGN, BXOR, BXOR_ASSIGN, COLON, DIV, DIV_ASSIGN, DO_WHILE, EQUAL, GE, GT, LAND, LE, LITERAL_CATCH, LITERAL_DO, LITERAL_FINALLY, LITERAL_FOR, LITERAL_IF, LITERAL_RETURN, LITERAL_SWITCH, LITERAL_SYNCHRONIZED, LITERAL_TRY, LITERAL_WHILE, LOR, LT, MINUS, MINUS_ASSIGN, MOD, MOD_ASSIGN, NOT_EQUAL, PLUS, PLUS_ASSIGN, QUESTION, SL, SL_ASSIGN, SR, SR_ASSIGN, STAR, STAR_ASSIGN, LITERAL_ASSERT, TYPE_EXTENSION"/>
    </module>

    <!-- Проверка использования фигурных скобок -->
    <module name="LeftCurly"/>
    <module name="RightCurly">
        <property name="option" value="alone"/>
        <property name="tokens" value="CLASS_DEF, METHOD_DEF, CTOR_DEF, LITERAL_FOR, LITERAL_WHILE, LITERAL_IF, STATIC_INIT, INSTANCE_INIT"/>
    </module>

    <!-- Проверка на наличие лишних импортов -->
    <module name="UnusedImports"/>

    <!-- Проверка наличия пробела после запятой в параметрах -->
    <module name="NoWhitespaceBefore">
        <property name="tokens" value="COMMA"/>
    </module>

    <!-- Проверка на наличие табуляции в конце строк -->
    <module name="Regexp">
        <property name="format" value="\t+$"/>
        <property name="message" value="Trailing tabs are not allowed"/>
    </module>

    <!-- Подавление ошибок по файлу suppressions.xml -->
    <module name="SuppressionFilter">
        <property name="file" value="suppressions.xml"/>
    </module>
</module>