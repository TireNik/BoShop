  "type": "record",
  "name": "OrderStatusChangedEvent",
  "namespace": "com.kika.avro.order",
  "fields": [
    { "name": "orderId", "type": "long" },
    { "name": "userId", "type": "long" },
    { "name": "oldStatus", "type": "string" },
    { "name": "newStatus", "type": "string" },
    {
      "name": "occurredAt",
      "type": {
        "type": "long",
        "logicalType": "timestamp-millis"
      },
      "default": 0
    }
  ]
}